{
"expo": {
"name": "Wonderbakes",
"slug": "sokohub",
"version": "1.0.0",
"orientation": "portrait",
"icon": "./assets/images/icon.png",
"scheme": "sokohub",
"userInterfaceStyle": "automatic",

"ios": {
  "supportsTablet": true
},

"android": {
  "adaptiveIcon": {
    "foregroundImage": "./assets/images/icon.png",
    "backgroundColor": "#FFF4E6"
  },
  "predictiveBackGestureEnabled": false,
  "package": "com.isackskyla.sokohub"
},

"web": {
  "bundler": "metro",
  "output": "static",
  "favicon": "./assets/images/notification-icon.png"
},

"plugins": [
  "expo-router",
  "expo-font",

  [
    "expo-splash-screen",
    {
      "image": "./assets/images/notification-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    }
  ],

  [
    "expo-notifications",
    {
      "icon": "./assets/images/notification-icon.png",
      "color": "#6b46c1"
    }
  ],

  "expo-web-browser",
  "expo-dev-client"
],

"experiments": {
  "typedRoutes": true
},

"extra": {
  "router": {},
  "eas": {
    "projectId": "41c96e3f-d6b2-49fd-bccc-323ce431dcfb"
  }
}

}
}
