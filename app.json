{
  "expo": {
    "name": "Wonderbakes",
    "slug": "sokohub",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/41c96e3f-d6b2-49fd-bccc-323ce431dcfb"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sokohub",
    "userInterfaceStyle": "automatic",
    "platforms":["android", "web"],
    "web": {
  "bundler": "metro",
  "output": "single",
  "favicon": "./assets/images/wonderbakes.png",
  "pwa": {
    "name": "Wonderbakes",
    "shortName": "Wonderbakes", "themeColor": "#6b46c1",
    "backgroundColor": "#ffffff",
    "display": "standalone",
    "startUrl": "/"
  }
},
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFF4E6"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.isackskyla.sokohub",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "sokohub",
              "host": "resetpassword",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "*.supabase.co",
              "pathPrefix": "/auth/v1/verify"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/notification-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
            [
        "expo-build-properties",
        {
          "android": {
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "useLegacyPackaging": true
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#6b46c1",
          "sounds": [
            "./assets/sounds/notification_sound.wav"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://sokohub.com"
      },
      "eas": {
        "projectId": "41c96e3f-d6b2-49fd-bccc-323ce431dcfb"
      }
    }
  }
}
